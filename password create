while True:
    password=input("enter your password ::: ")
    if len(password)>=8:
        upp_count=0
        low_count=0
        num_count=0
        spl_count=0
        for i in password:
            if i.isupper():
                upp_count+=1
            elif i.islower():
                low_count+=1
            elif i.isdigit():
                num_count+=1
            else:
                spl_count+=1
        if upp_count>=1 and low_count>=1 and num_count>=1 and spl_count>=1:
            print("your password is accepted *\/* !!! ")
        else:
            print("noop plz enter correct password")
    else:
        print("enter min 8 char")
        
