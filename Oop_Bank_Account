

class Bank_Account:

    def __init__(self,account_holder, balance):
        self.account_holder=account_holder
        self.balance=balance
        print(f"Account User :{account_holder}")
        print(f"Initial Account Balance :{balance}")
        print("_" * 20)

    def deposit(self,amount):
        self.amount=amount
        self.balance+=amount
        print(f"\nyour deposit amounts {self.amount} successful....")
        print(f"\nYour Account total balance : {self.balance}")
        print("_" * 20)

    def withdraw (self,amount):
        if amount > self.balance:
            print(f"enter your amount is less than your balance {self.balance}")
            print(f"enter your correct amount")
            print("_" * 20)

        else:
            self.balance-= amount
            print(f"your withdraw amount is {amount} successful..")
            print((f"Your Account total balance : {self.balance}"))
            print("_" * 20)

    def get_balance (self):
        print(f"Your total balance amount is {self.balance}/-")


